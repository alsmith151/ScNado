import pandas as pd
from pathlib import Path
try:
    import scnado
    DEFAULT_BARCODES = scnado.get_barcode_csv()
except ImportError:
    DEFAULT_BARCODES = "python/scnado/data/barcodes_extracted.csv"

configfile: "config/config.yaml"

samples = pd.read_csv(config["samples"], sep="\t").set_index(["sample", "sublibrary"], drop=False)

# Configuration flags for which analyses to run
ENABLE_CAT = config.get("enable_cat", True)
ENABLE_RNA = config.get("enable_rna", True)
ENABLE_INTEGRATION = config.get("enable_integration", ENABLE_CAT and ENABLE_RNA)

def get_barcode_csv(wildcards):
    return config.get("barcode_csv", DEFAULT_BARCODES)

def get_fastq_r1(wildcards):
    return samples.loc[(wildcards.sample, wildcards.sublibrary), "fastq_r1"]

def get_fastq_r2(wildcards):
    return samples.loc[(wildcards.sample, wildcards.sublibrary), "fastq_r2"]

def get_final_outputs():
    outputs = []
    
    if ENABLE_INTEGRATION and ENABLE_CAT and ENABLE_RNA:
        outputs.extend(expand("results/integrated/{sample}.h5mu", sample=samples["sample"].unique()))
    
    if ENABLE_CAT:
        outputs.extend(expand("results/processed_cat/{sample}.h5ad", sample=samples["sample"].unique()))
        outputs.extend(expand("results/coverage/{sample}/", sample=samples["sample"].unique()))
    
    if ENABLE_RNA:
        outputs.extend(expand("results/processed_rna/{sample}.h5ad", sample=samples["sample"].unique()))
    
    return outputs

rule all:
    input:
        get_final_outputs()

rule find_barcodes:
    input:
        r1=get_fastq_r1,
        r2=get_fastq_r2,
        barcodes=get_barcode_csv
    output:
        r1="results/barcoded/{sample}_{sublibrary}_R1.fastq.gz",
        r2="results/barcoded/{sample}_{sublibrary}_R2.fastq.gz"
    log:
        "logs/find_barcodes/{sample}_{sublibrary}.log"
    container:
        config["scnado_container"]
    resources:
        mem="1G",
        runtime='4h',
    threads: 8
    shell:
        "scnado find-barcodes "
        "--r1 {input.r1} "
        "--r2 {input.r2} "
        "--barcodes {input.barcodes} "
        "--output-prefix results/barcoded/{wildcards.sample}_{wildcards.sublibrary} "
        "--n-missmatches {config[barcode_mismatches]} "
        "--enable-n-to-match"
        " > {log} 2>&1"

rule align_cat:
    input:
        r1="results/barcoded/{sample}_{sublibrary}_R1.fastq.gz",
    output:
        bam="results/aligned_cat/{sample}_{sublibrary}.bam"
    container:
        "oras://ghcr.io/alsmith151/seqnado_pipeline:latest"
    threads: 8
    resources:
        mem=lambda wc, attempt: f"{16 ** 2 * attempt}G",
        runtime='4h',        
    params:
        index=config["bowtie2_index"]
    shell:
        """
        bowtie2 -p {threads} -x {params.index} -U {input.r1} | \
        samtools view -@ {threads} -b - > {output.bam}.unsorted.bam && \
        samtools sort -@ {threads} -o {output.bam} {output.bam}.unsorted.bam && \
        rm {output.bam}.unsorted.bam
        """

rule make_fragments:
    input:
        bam="results/aligned_cat/{sample}_{sublibrary}.bam"
    output:
        fragments="results/fragments/{sample}_{sublibrary}_fragments.tsv.gz"
    container:
        config["scnado_container"]
    resources:
        mem="6G",
        runtime='1h',
    shell:
        "scnado fragments "
        "--bam {input.bam} "
        "--output {output.fragments} "
        "--barcode-regex '^[^|]+\|(?P<barcode>[ACGT-]+)\|'"
        "--umi-regex '|(?P<UMI>[ATGC]+)$'"
        "--shift-plus 4 --shift-minus -5"

rule process_cat:
    input:
        fragments=lambda wildcards: expand("results/fragments/{sample}_{sublib}_fragments.tsv.gz", 
                                          sample=wildcards.sample, 
                                          sublib=samples.loc[samples["sample"] == wildcards.sample, "sublibrary"])
    output:
        h5ad="results/processed_cat/{sample}.h5ad"
    container:
        "docker://quay.io/biocontainers/snapatac2:2.8.0--py311h284d45d_1"
    script:
        "scripts/process_cat.py"

rule export_coverage:
    input:
        h5ad="results/processed_cat/{sample}.h5ad"
    output:
        directory("results/coverage/{sample}/")
    container:
        "docker://quay.io/biocontainers/snapatac2:2.8.0--py311h284d45d_1"
    script:
        "scripts/export_coverage.py"
    resources:
        mem="12G",
        runtime='4h',